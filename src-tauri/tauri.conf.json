{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude X",
  "version": "0.2.1",
  "identifier": "com.ictpelindo4.claude-desktop-custom",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Claude X",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true
      }
    ],
    "security": {
      "assetProtocol": { "enable": true, "scope": ["**"] },
      "csp": "default-src 'self' asset: http://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost blob:; connect-src 'self' https://api.github.com https://raw.githubusercontent.com https://github.com https://objects.githubusercontent.com ipc: http://ipc.localhost asset: http://asset.localhost"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/aikamz101010-alt/myClaude/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0MjA5QjU1MEIyNTNGMzMKUldRelB5VUxWWnNnZEVFc0h0Rk5yTVhuN3lzVG5jNUEzRmkrZXo5c05SRFhzcHdDTGpDenNFWEwK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../sidecar/agent.mjs": "sidecar/agent.mjs",
      "../node_modules/@anthropic-ai/claude-agent-sdk": "sidecar/node_modules/@anthropic-ai/claude-agent-sdk"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
